{
  "identifier": "diagnostic-capability",
  "description": "Diagnostic browser window — remote page can emit capture data back to Rust only",
  "windows": ["diagnostic"],
  "remote": {
    "urls": [
      "http://*:*/*",
      "https://*:*/*",
      "http://*/*",
      "https://*/*"
    ]
  },
  "permissions": ["core:event:allow-emit"]
}
